{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "enabledMcpjsonServers": ["a11y-context"],
  "permissions": {
    "allow": [
      "mcp__a11y-context__*"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",

      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(./secrets/**)",

      "Write(./.env)",
      "Write(./.env.*)",
      "Write(./secrets/**)",

      "Edit(./.claude/settings.json)",
      "Write(./.claude/settings.json)",
      "Edit(./.mcp.json)",
      "Write(./.mcp.json)"
    ],
    "ask": []
  }
}
